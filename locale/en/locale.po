msgid "plugins.generic.getftr.displayName"
msgstr "GetFTR Integration Plugin"

msgid "plugins.generic.getftr.description"
msgstr "Integrates with GetFTR to display GetFTR indicators and smart links when the user's institution entitles them to full text or content is Open Access. "
"It also flags where content has been retracted or updated."
"<br>"
"A valid GetFTR Integrator ID is required. "
"For setup instructions, please refer to the plugin's <a href="https://github.com/getft/getft-ojs-plugin?tab=readme-ov-file">README</a> or the GetFTR <a href="https://docs.getfulltextresearch.com/latest/integrators/ojs-plugin">documentation</a>."

msgid "plugins.generic.getftr.settings"
msgstr "Settings"

msgid "plugins.generic.getftr.settings.info"
msgstr "Configure your GetFTR integration settings below. You must provide an Integrator ID obtained from GetFTR to enable the service."
"<br>"
"Please check out our <a href="https://docs.getfulltextresearch.com/latest/integrators/ojs-plugin">documentation</a> and/or the plugin's <a href="https://github.com/getft/getft-ojs-plugin?tab=readme-ov-file">README</a>."

msgid "plugins.generic.getftr.settings.integratorId"
msgstr "GetFTR Integrator ID"

msgid "plugins.generic.getftr.settings.integratorIdRequired"
msgstr "A valid GetFTR Integrator ID is required to activate GetFTR integration."

msgid "plugins.generic.getftr.settings.settingsUpdated"
msgstr "GetFTR settings have been successfully updated."